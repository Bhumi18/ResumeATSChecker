# Neon Database Configuration
# Note: DATABASE_URL is for server-side, VITE_NEON_DATABASE_URL is for client-side checks
DATABASE_URL=your_neon_database_url
VITE_NEON_DATABASE_URL=your_neon_database_url

# Clerk Configuration
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

# Google AI Studio API Key (Required)
# Get your API key from: https://aistudio.google.com/app/apikey
# Models used:
#   - gemini-2.0-flash-exp: Fast analysis & feedback
#   - gemini-2.0-flash-exp: Deep rewrite & premium analysis  
#   - text-embedding-004: Semantic matching & embeddings
# Server-side (used by API routes / SSR):
GOOGLE_AI_STUDIO_API_KEY=your_google_ai_studio_api_key

# Optional (client-side builds only; server will also read this if present):
VITE_GOOGLE_AI_STUDIO_API_KEY=your_google_ai_studio_api_key

# Google OAuth Configuration (for Sign in with Google)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# See GOOGLE_OAUTH_SETUP.md for detailed setup instructions
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5174/api/auth/google/callback
